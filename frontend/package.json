{
  "name": "aluminum-bypass-frontend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --configLoader native",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
