    "element-plus": "^2.8.4",
    "pinia": "^2.2.4",
    "qrcode": "^1.5.4",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.3"
  }
